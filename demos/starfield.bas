10 REM STARFIELD DEMO
20 NS=15:REM NUMBER OF STARS
30 DIM SX(NS),SY(NS),DX(NS),DY(NS),SC(NS)
40 CLS0
50 CX=32:CY=16
60 FOR I=1 TO NS:GOSUB 200:NEXT
70 REM MAIN LOOP
80 FOR I=1 TO NS
90 RESET(SX(I),SY(I))
100 SX(I)=SX(I)+DX(I)
110 SY(I)=SY(I)+DY(I)
120 IF SX(I)<0 OR SX(I)>63 OR SY(I)<0 OR SY(I)>31 THEN GOSUB 200
130 SET(SX(I),SY(I),SC(I))
140 NEXT I
150 GOTO 80
200 REM INIT STAR I
210 A=RND(0)*6.28
220 R=RND(0)*1.5+.5
230 DX(I)=COS(A)*R
240 DY(I)=SIN(A)*R
250 IF ABS(DX(I))<.3 AND ABS(DY(I))<.3 THEN 210
260 SX(I)=CX:SY(I)=CY
270 SC(I)=INT(RND(0)*8)+1
280 RETURN
